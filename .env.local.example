# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Booking.com Connectivity API
BOOKING_COM_USERNAME=
BOOKING_COM_PASSWORD=
BOOKING_COM_HOTEL_IDS=
# Set this once Booking.com Connectivity messaging API is enabled via middleman partner
BOOKING_COM_MESSAGING_API_KEY=

# Airbnb API
AIRBNB_CLIENT_ID=
AIRBNB_CLIENT_SECRET=

# Nuki
NUKI_API_TOKEN=
NUKI_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=checkin@yourdomain.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Encryption key for PII (AES-256, 32 bytes, base64 encoded)
ENCRYPTION_KEY=

# Accounting API
ACCOUNTING_API_URL=
ACCOUNTING_API_KEY=

# Admin
ADMIN_EMAIL=

# Branding (shown in page title and UI)
NEXT_PUBLIC_PROPERTY_NAME=Your Property Name

# Cron secret (shared between Supabase cron and the app)
CRON_SECRET=

# Guest onboarding URL — place this in your Booking.com automated message template
# (Extranet → Property → Messaging → Automated messages)
# ONBOARDING_URL=https://checkin.yourdomain.com/welcome
